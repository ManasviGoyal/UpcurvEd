# backend/Dockerfile.dev
# Backend - dev image (Python 3.12 + uv + dev deps)
FROM python:3.12-slim-bookworm

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8
ENV PYTHONUNBUFFERED=1
# uv config
ENV UV_LINK_MODE=copy
ENV UV_PROJECT_ENVIRONMENT=/home/app/.venv
ENV PATH="/home/app/.venv/bin:${PATH}"

RUN set -ex; \
    apt-get update && \
    apt-get install -y --no-install-recommends \
      build-essential \
      curl \
      ffmpeg \
      sox \
      libsox-fmt-all \
      pkg-config \
      libcairo2-dev \
      libpango1.0-dev \
      libgl1-mesa-dev \
      libglib2.0-0 \
      texlive-latex-base \
      texlive-latex-recommended \
      texlive-latex-extra \
      texlive-fonts-recommended \
      texlive-fonts-extra \
      texlive-science \
      dvisvgm \
      ghostscript \
    && apt-get clean && rm -rf /var/lib/apt/lists/* && \
    python -m pip install --no-cache-dir --upgrade pip uv

# Non-root user & workspace
RUN useradd -ms /bin/bash app -d /home/app -u 1000
USER app
WORKDIR /app

# Copy project metadata first for dependency layer
COPY --chown=app:app backend/pyproject.toml ./pyproject.toml
COPY --chown=app:app backend/uv.lock ./uv.lock

# Install with dev group (ruff, pytest, etc.)
RUN uv sync --all-extras --dev

# Entrypoint (code will be bind-mounted by compose)
COPY --chown=app:app backend/docker-entrypoint.sh /app/docker-entrypoint.sh
RUN chmod +x /app/docker-entrypoint.sh

EXPOSE 8000
ENTRYPOINT ["/bin/bash", "/app/docker-entrypoint.sh"]
