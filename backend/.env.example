# Backend runtime configuration
APP_MODE=cloud
# Use APP_MODE=desktop-local for local desktop runtime (disables mandatory Firebase token verification).
RAG_USE_CLOUD=true
# In compose: http://rag-service:8001 ; outside: http://localhost:8001
RAG_SERVICE_URL=http://rag-service:8001

# Artifact bucket (preferred) or fallback to GCS_BUCKET
GCS_ARTIFACT_BUCKET=your-artifacts-bucket

# ADC path inside container
GOOGLE_APPLICATION_CREDENTIALS=/secrets/service-account.json


# Set your GCP project ID here for all backend config
GCP_PROJECT=your-project-id
# Use the variable below for all service account references
GCS_SIGNER_SERVICE_ACCOUNT=gcs-signer@${GCP_PROJECT}.iam.gserviceaccount.com
