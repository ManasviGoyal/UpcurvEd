# frontend/Dockerfile.dev
# Frontend - Vite dev container
FROM node:20-alpine

WORKDIR /app
EXPOSE 8080

# Keep container lean; deps are installed at runtime from mounted code
RUN apk add --no-cache bash

# Default to a shell; compose command runs npm install && npm run dev
ENTRYPOINT ["/bin/sh","-lc","npm ci && npm run dev -- --host 0.0.0.0 --port 8080"]
